{
  "name": "mini-aws",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter !mini-aws dev",
    "dev:api": "pnpm --filter api-gateway dev",
    "dev:customers": "pnpm --filter customers-service dev",
    "dev:catalog": "pnpm --filter catalog-service dev",
    "dev:orders": "pnpm --filter orders-service dev",
    "dev:view": "pnpm --filter derived-view-service dev",
    "dev:logs": "pnpm --filter logs-service dev",
    "dev:assets": "pnpm --filter assets-service dev",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r --filter !mini-aws build",
    "test:e2e": "tsx --test backend/tests/*.e2e.ts"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.3.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ]
  }
}
