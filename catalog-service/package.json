{
  "name": "catalog-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/catalog-producer.ts",
    "build": "tsup src/catalog-producer.ts --format esm",
    "typecheck": "tsc --noEmit"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.3.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "shared-contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
