{
  "name": "catalog-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/catalog-worker.ts",
    "build": "tsup src/catalog-worker.ts --format esm",
    "typecheck": "tsc --noEmit"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.3.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "kysely": "^0.29.2",
    "pg": "^8.21.0",
    "shared-contracts": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
